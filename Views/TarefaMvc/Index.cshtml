    ViewData["Title"] = "Listagem de tarefas";
}

<h2>Tarefas</h2>
<p><a asp-action="Criar" class="btn btn-success">Nova tarefa</a></p>

<br />

<!-- O model binder preenche o objeto 'filtro' automaticamente -->
<form method="get" class="row g-3 mb-3">
    <div class="col-auto">
        <input type="text" name="Titulo" value="@Model.Titulo" class="form-control" placeholder="Buscar por titulo" />
    </div>
    <div class="col-auto">
        <input type="text" name="Descricao" value="@Model.Descricao" class="form-control"
               placeholder="Buscar por descrição" />
    </div>
    <div class="col-auto">
        <input type="date" name="Data" value="@Model.Data?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-auto">
        <select name="Status" class="form-select" asp-items="Html.GetEnumSelectList<EnumStatusTarefa>()">
            <option value="">Selecione Status...</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <a asp-action="Index" class="btn btn-secondary">Limpar</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Tarefas.FirstOrDefault().Id)</th>
            <th>@Html.DisplayNameFor(model => model.Tarefas.FirstOrDefault().Titulo)</th>
            <th>@Html.DisplayNameFor(model => model.Tarefas.FirstOrDefault().Descricao)</th>
            <th>@Html.DisplayNameFor(model => model.Tarefas.FirstOrDefault().Data)</th>
            <th>@Html.DisplayNameFor(model => model.Tarefas.FirstOrDefault().Status)</th>
            <th>Ação</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Tarefas)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Titulo</td>
                <td>@item.Descricao</td>
                <td>@item.Data</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Editar</a> |
                    <a asp-action="Detalhar" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Detalhar</a> |
                    <a asp-action="Deletar" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Deletar</a>
                </td>
            </tr>
        }
    </tbody>
</table> *@





@* 

@model MVC.Models.TarefasFiltroViewModel

@{
    ViewData["Title"] = "Listagem de Tarefas";
}

<div class="container">
    <h2>@ViewData["Title"]</h2>

    <!-- Formulário de Filtros (Clean Code: Facilita a interação do usuário) -->
    <form method="get" asp-action="Index" class="row g-3 mb-4">
        <div class="col-md-3">
            <input type="text" name="titulo" class="form-control" placeholder="Título" value="@Model.Titulo" />
        </div>
        <div class="col-md-3">
            <input type="text" name="descricao" class="form-control" placeholder="Descrição" value="@Model.Descricao" />
        </div>
        <div class="col-md-2">
            <input type="date" name="data" class="form-control" value="@Model.Data?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-2">
            <select name="status" class="form-select">
                <option value="">Todos</option>
                @foreach (var status in Enum.GetValues(typeof(EnumStatusTarefa)))
                {
                    <option value="@status" selected="@(Model.Status.ToString() == status.ToString())">@status</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </form>

    <!-- Tabela de Dados -->
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Título</th>
                <th>Descrição</th>
                <th>Data</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tarefa in Model.Tarefas)
            {
                <tr>
                    <td>@tarefa.Titulo</td>
                    <td>@tarefa.Descricao</td>
                    <td>@tarefa.Data.ToShortDateString()</td>
                    <td>@tarefa.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div> *@